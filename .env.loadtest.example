# Yük testi ortam değişkenleri — şablon. Kopyala:  cp .env.loadtest.example .env.loadtest
# Sonra Supabase Dashboard → Project Settings → API'den değerleri gir.
# .env.loadtest GITIGNORE'ludur; service_role anahtarı ASLA commit'lenmez/paylaşılmaz.

# Project URL  (Settings → API → Project URL) — uygulamanın kullandığı URL ile aynı
LOADTEST_URL=https://xxxxxxxxxxxx.supabase.co

# anon/public key (Settings → API → Project API keys → anon public) — herkese açık, güvenli
LOADTEST_ANON_KEY=eyJ...

# service_role key (Settings → API → Project API keys → service_role → Reveal)
# ⚠️ TAM YETKİ, RLS bypass. Yalnız seed + cleanup için. Uygulamaya/APK'ya asla koyma.
LOADTEST_SERVICE_ROLE_KEY=eyJ...

# ── İsteğe bağlı (varsayılanlar iyi) ──────────────────────────────────────
# Test hesabı havuzu kimliği (işaretli domain → gerçek kullanıcıdan ayırt edilir)
# LOADTEST_ACCOUNT_PREFIX=loadtest+
# LOADTEST_ACCOUNT_DOMAIN=loadtest.local
# LOADTEST_ACCOUNT_PASSWORD=LoadTest!2026#pool
# LOADTEST_REPORT_DIR=/tmp/.../scratchpad
