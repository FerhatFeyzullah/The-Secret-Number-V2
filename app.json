{
  "expo": {
    "name": "Gizemli Sayılar",
    "slug": "gizemli-sayilar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "gizemlisayilar",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app-icon.png",
      "bundleIdentifier": "com.gizemlisayilar.app"
    },
    "android": {
      "package": "com.gizemlisayilar.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0C0F19",
        "foregroundImage": "./assets/images/app-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0F19",
          "image": "./assets/images/app-icon-foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0C0F19",
            "image": "./assets/images/app-icon-foreground.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-audio",
      "expo-asset",
      "./plugins/with-local-java-home.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13a7de1a-5cb8-4130-a91e-bd9fbe1f4ff0"
      }
    },
    "owner": "vavizof"
  }
}
